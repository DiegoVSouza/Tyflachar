# ── App ──────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080

# ── Database & Cache ─────────────────────────────────────────────
DATABASE_URL="postgres://user:password@host:5432/dbname"
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-secret"

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="https://tyflachar.pages.dev,http://localhost:3000"

# ── Meta / WhatsApp ───────────────────────────────────────────────
META_API_VERSION=v18.0
META_PHONE_NUMBER_ID=""
META_WABA_TOKEN=""
META_WEBHOOK_VERIFY_TOKEN=""
META_APP_SECRET=""

# ── Branch defaults ───────────────────────────────────────────────
DEFAULT_BRANCH_ID=1

# ── LLM / Claude (optional — set to enable AI mode) ──────────────
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Enable per branch: set branches.bot_mode = 'llm' in the DB.
